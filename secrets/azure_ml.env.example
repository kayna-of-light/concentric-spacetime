# Azure ML workspace configuration
# Copy to secrets/azure_ml.env and fill in your values
AZURE_ML_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_ML_RESOURCE_GROUP=<your-resource-group>
AZURE_ML_WORKSPACE=<your-workspace-name>
AZURE_ML_GPU_COMPUTE=<gpu-compute-target>
AZURE_ML_CPU_COMPUTE=<cpu-compute-target>
AZURE_ML_EXPERIMENT=ds-numerical-experiments
